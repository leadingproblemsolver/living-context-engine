{
  "name": "driftguard",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "preview": "npm run build && wrangler dev --config .output/server/wrangler.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test scripts/judgment-contract.test.mjs",
    "schema:sync": "node scripts/sync-schema.mjs",
    "check:release": "node scripts/release-check.mjs",
    "check:deno": "node scripts/deno-check.mjs",
    "check:edge": "npm run check:deno && node scripts/check-edge.mjs",
    "validate": "npm run schema:sync && npm run check:release && npm test && npm run check:edge && npm run typecheck && npm run lint && npm run format:check && npm run build",
    "check:env:frontend": "node scripts/env-check.mjs frontend",
    "check:env:backend": "node scripts/env-check.mjs backend",
    "check:env": "node scripts/env-check.mjs all",
    "supabase:login": "npx --yes supabase@2.109.0 login",
    "supabase:link": "npx --yes supabase@2.109.0 link",
    "supabase:secrets": "npx --yes supabase@2.109.0 secrets set --env-file supabase/functions/.env.local",
    "supabase:db": "npm run schema:sync && npx --yes supabase@2.109.0 db push",
    "supabase:functions": "npx --yes supabase@2.109.0 functions deploy --no-verify-jwt",
    "supabase:local": "npx --yes supabase@2.109.0 start && npx --yes supabase@2.109.0 functions serve --env-file supabase/functions/.env.local",
    "deploy:backend": "npm run check:env:backend && npm run supabase:db && npm run supabase:secrets && npm run supabase:functions",
    "deploy:web": "npm run check:env:frontend && npm run build && wrangler deploy --config .output/server/wrangler.json",
    "supabase:function:evaluate": "npx --yes supabase@2.109.0 functions deploy evaluate --no-verify-jwt",
    "supabase:function:infer": "npx --yes supabase@2.109.0 functions deploy infer-guardrails --no-verify-jwt",
    "supabase:functions:api": "npx --yes supabase@2.109.0 functions deploy --no-verify-jwt --use-api",
    "smoke:worker": "npm run build && node scripts/worker-smoke.mjs",
    "release:verify": "npm run validate && node scripts/worker-smoke.mjs && npm audit --audit-level=low"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "2.7.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.7.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "8.0.16",
    "wrangler": "4.107.0"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.9.2",
  "version": "1.0.0"
}
