# DriftGuard frontend environment
# Copy to .env.local for local development.
# Copy the same values into your web host's environment settings for production.
# VITE_* variables are intentionally public and are bundled into the browser.

# Supabase Dashboard -> Project Settings -> API -> Project URL
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Dashboard -> Project Settings -> API Keys -> Publishable key
# Expected modern format: sb_publishable_...
# A legacy anon JWT also works, but publishable keys are preferred.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_YOUR_KEY
