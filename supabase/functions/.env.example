# DriftGuard Supabase Edge Function secrets
# Copy to supabase/functions/.env.local for local function development only.
# Never prefix these values with VITE_. Never commit the populated file.
# Production command: npx supabase secrets set --env-file supabase/functions/.env.local

# OpenAI-compatible chat-completions endpoint.
AI_BASE_URL=https://api.openai.com/v1

# OpenAI API key. Replace locally and in Supabase secrets.
AI_API_KEY=sk-REPLACE_WITH_YOUR_SERVER_ONLY_KEY

# Pinned model snapshot for repeatable judgment behavior.
# Replace only after rerunning the judgment contract tests.
AI_MODEL=gpt-5.4-mini-2026-03-17

# Provider behavior. "json_object" is supported by the default OpenAI model.
# Set to "none" only for a compatible gateway that rejects response_format.
AI_RESPONSE_FORMAT=json_object

# GPT-5.4 mini supports none/low/medium/high/xhigh. "none" minimizes latency for schema-bound judgment.
AI_REASONING_EFFORT=none

# Hard request controls.
AI_TIMEOUT_MS=30000
AI_MAX_OUTPUT_TOKENS=4000

# Comma-separated browser origins allowed to call the functions.
# Set your exact production origin before deploying.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://YOUR_PRODUCTION_DOMAIN
